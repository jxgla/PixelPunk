# PixelPunk production environment example
# Copy to `.env` and fill with strong random values before deployment.
# Personal low-traffic recommendation: keep conservative rate limits and small upload size.

PORT=9520

# MySQL credentials (required)
MYSQL_ROOT_PASSWORD=change_me_to_a_very_strong_random_password
MYSQL_PASSWORD=change_me_to_a_very_strong_random_password

# Redis credentials (required)
REDIS_PASSWORD=change_me_to_a_very_strong_random_password

# CORS allowed origins (comma separated)
# Example: https://img.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=https://your-domain.example

# API / Upload / Download rate limit (per IP)
API_RATE_LIMIT_RPS=8
API_RATE_LIMIT_BURST=16
UPLOAD_RATE_LIMIT_RPS=1
UPLOAD_RATE_LIMIT_BURST=2
DOWNLOAD_RATE_LIMIT_RPS=4
DOWNLOAD_RATE_LIMIT_BURST=8

# Pause all uploads when total stored files reach this threshold (GB)
# Set 0 to disable this protection.
UPLOAD_PAUSE_THRESHOLD_GB=5

# When threshold reached, allow only admin/super-admin uploads.
# true: block guest/user uploads, keep admin uploads available
# false: block all uploads
UPLOAD_ALLOW_ADMIN_ONLY_WHEN_THRESHOLD_REACHED=true
